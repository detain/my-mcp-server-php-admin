{
    "name": "myadmin/admin-mcp-proxy",
    "description": "Standalone MCP proxy server for MyAdmin admin API",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "mcp/sdk": "dev-main",
        "guzzlehttp/guzzle": "^7.8",
        "symfony/yaml": "^6.4|^7.0",
        "symfony/uid": "^6.4|^7.0",
        "php-http/message": "^1.16",
        "nyholm/psr7": "^1.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "AdminMcp\\": "src/"
        }
    },
    "bin": ["bin/mcp"],
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@ensure-dirs"
        ],
        "post-update-cmd": [
            "@ensure-dirs"
        ],
        "ensure-dirs": [
            "@php -r \"foreach (['cache','sessions'] as $suffix) { if (!is_dir('var/'.$suffix)) mkdir('var/'.$suffix, 0777, true); }\""
        ]
    },
    "minimum-stability": "stable"
}
