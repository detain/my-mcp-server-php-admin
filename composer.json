{
    "name": "myadmin/admin-mcp-proxy",
    "description": "Standalone MCP proxy server for MyAdmin admin API",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "guzzlehttp/guzzle": "^7.8",
        "mcp/sdk": "dev-main",
        "nyholm/psr7": "^1.8",
        "php-http/message": "^1.16",
        "symfony/uid": "^6.4|^7.0",
        "symfony/yaml": "^6.4|^7.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.11",
        "phpstan/phpstan-deprecation-rules": "^1.2",
        "phpstan/phpstan-strict-rules": "^1.6",
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "AdminMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AdminMcp\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/mcp"],
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@ensure-dirs"
        ],
        "post-update-cmd": [
            "@ensure-dirs"
        ],
        "ensure-dirs": [
            "@php -r \"@mkdir('var/cache', 0777, true); @mkdir('var/sessions', 0777, true);\""
        ],
        "lint": "@php tools/lint.php",
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html=coverage --coverage-text",
        "test-coverage-clover": "phpunit --coverage-clover=coverage.xml",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "phpstan-baseline": "phpstan analyse --memory-limit=512M --generate-baseline",
        "bundle-validate": "npx --yes @anthropic-ai/mcpb validate mcpb/manifest.json",
        "bundle-build": "mcpb/scripts/build-bundle.sh",
        "bundle-clean": "rm -rf mcpb/build mcpb/dist",
        "bundle": [
            "@bundle-validate",
            "@bundle-build"
        ],
        "ci": [
            "@lint",
            "@phpstan",
            "@test"
        ],
        "ci-full": [
            "@lint",
            "@phpstan",
            "@test",
            "@bundle-validate"
        ]
    },
    "scripts-descriptions": {
        "lint": "Run `php -l` on every PHP source/test/script file",
        "test": "Run the PHPUnit test suite",
        "test-coverage": "Run PHPUnit with HTML + text coverage report (requires Xdebug or PCOV)",
        "test-coverage-clover": "Run PHPUnit with a Clover coverage XML (for CI / Codecov)",
        "phpstan": "Run PHPStan static analysis",
        "phpstan-baseline": "Regenerate the PHPStan baseline file",
        "bundle-validate": "Validate mcpb/manifest.json against the MCPB schema (needs npx)",
        "bundle-build": "Build the .mcpb bundle into mcpb/dist/ (runs validate as part of pack)",
        "bundle-clean": "Remove mcpb/build/ and mcpb/dist/",
        "bundle": "Validate the manifest, then build the .mcpb bundle",
        "ci": "Run lint + PHPStan + tests — what CI runs",
        "ci-full": "Run lint + PHPStan + tests + bundle-validate — full pre-release check"
    },
    "minimum-stability": "stable"
}
