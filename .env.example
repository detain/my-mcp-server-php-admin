OPENAPI_SPEC_URL=https://my.interserver.net/admin/spec/openapi-admin.yaml
API_BASE_URL=https://my.interserver.net/apiv2/admin
SESSION_DIR=/tmp/mcp_admin_sessions
CACHE_DIR=/tmp/mcp_admin_cache
SERVER_NAME=myadmin-admin-mcp
SERVER_VERSION=1.0.0

# Path to a CA bundle (PEM). Applied via ini_set to curl.cainfo and openssl.cafile,
# and passed to Guzzle so it sets CURLOPT_CAINFO on outbound requests. Leave empty
# to use the system default trust store.
CA_CERT_FILE=

# Verify TLS peer + host on outbound API calls. true/false (default: true).
# Maps to CURLOPT_SSL_VERIFYPEER and CURLOPT_SSL_VERIFYHOST.
SSL_VERIFY=true
